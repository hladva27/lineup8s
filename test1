<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Football Team Board</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    body {
      margin: 0;
      font-family: Arial;
      background: #0f172a;
      color: white;
      text-align: center;
    }

    .pitch {
      width: 90vw;
      max-width: 900px;
      height: 550px;
      margin: 20px auto;
      background: green;
      position: relative;
      border: 4px solid white;
    }

    .player {
      width: 50px;
      height: 50px;
      border-radius: 50%;
      position: absolute;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      cursor: grab;
    }

    .red { background: red; }
    .white { background: white; color: black; }
  </style>
</head>
<body>

<h2>Football Team Board</h2>

<div class="pitch" id="pitch"></div>

<script>
  const pitch = document.getElementById("pitch");

  const players = [];

  function createPlayer(name, team, x, y) {
    const div = document.createElement("div");
    div.className = "player " + team;
    div.innerText = name;
    div.style.left = x + "px";
    div.style.top = y + "px";

    let offsetX, offsetY, dragging = false;

    div.onmousedown = (e) => {
      dragging = true;
      offsetX = e.offsetX;
      offsetY = e.offsetY;
    };

    document.onmousemove = (e) => {
      if (!dragging) return;
      div.style.left = (e.pageX - pitch.offsetLeft - offsetX) + "px";
      div.style.top = (e.pageY - pitch.offsetTop - offsetY) + "px";
    };

    document.onmouseup = () => dragging = false;

    pitch.appendChild(div);
  }

  // default players
  for (let i = 0; i < 8; i++) {
    createPlayer("R" + (i+1), "red", 50, i * 60 + 20);
    createPlayer("W" + (i+1), "white", 750, i * 60 + 20);
  }
</script>

</body>
</html>
